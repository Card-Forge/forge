  "tells": [
    "Be cautious of self-inflicted life loss from Queza and Psychosis Crawler",
    "always calculate triggers before casting spells.",
    "Marauding Blight-Priest is a double-edged sword\u2014sacrificing it for life gain and damage can backfire if you're low on life.",
    "In formats with graveyard hate, consider reducing recursion spells and focusing on in-the-board synergy.",
    "Always track opponent's life total relative to your triggers to avoid accidental losses."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast a cantrip or cheap spell to trigger life loss/card draw, then pass."
    },
    {
      "trigger": "early game",
      "line": "If holding a 1-drop creature, play it instead."
    },
