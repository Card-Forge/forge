  "tells": [
    "Remember that Ashling's second-spell trigger only counts spells you cast, not tokens or triggered abilities.",
    "Risen Reef triggers on every spell you cast, so stacking cheap cantrips is key.",
    "Avoid overcommitting to one big spell",
    "the deck wins through volume.",
    "Watch for 'summoning sickness' on your tokens\u2014they can attack immediately if they enter on your turn, but be mindful of combat math."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast Sol Ring or a cheap mana artifact."
    },
    {
      "trigger": "early game",
      "line": "If possible, cast a 1-mana cantrip or creature to start the 'second spell' trigger."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Ramp into dual lands or fetch basics, cast a second spell to trigger Ashling/Risen Reef, or play Ashling directly if mana allows."
    }
