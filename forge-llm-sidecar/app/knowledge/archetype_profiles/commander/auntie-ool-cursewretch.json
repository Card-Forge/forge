    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast a cheap Curse or noncreature spell if mana allows."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Play a second land, cast another noncreature spell to grow Ool, or deploy a sacrifice outlet like Ignoble Hierarch."
