  "tells": [
    "Common mistake: Attacking with Giada without tapping creatures to pump her, leaving her vulnerable to removal or unable to close the game.",
    "Always calculate pump math before committing.",
    "Another mistake: Overcommitting to the board without considering sweepers.",
    "Use tokens as a buffer, not just for damage.",
    "Giada's lifelink is crucial for stabilizing against aggressive decks, so don't neglect blocking."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, drop Sol Ring or other ramp."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Cast Giada if possible, or play a cheap land/ramp to set up for Turn 3 Giada."
    },
    {
      "trigger": "early game",
      "line": "If you can't cast Giada early, use ramp to accelerate and play cheap white creatures or equipment to stabilize."
    }
