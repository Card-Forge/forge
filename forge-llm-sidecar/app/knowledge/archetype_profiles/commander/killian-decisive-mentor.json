  "tells": [
    "Commander tax is a major factor",
    "include ways to reduce it (Crown of Convergence, Commander's Sphere, etc.).",
    "Killian's ability is tap, so you can't attack and generate tokens on the same turn unless you have haste or double strike.",
    "Watch out for 'cantrip' effects that let you dig for answers.",
    "Common mistake: Overcommitting to board without removal for sweepers."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast Sol Ring or Arcane Signet."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Play a second land, cast Killian if you have W mana, or play a cheap token producer/removal."
    },
    {
      "trigger": "early game",
      "line": "If you can't cast Killian T2, use signet to cast it T3."
