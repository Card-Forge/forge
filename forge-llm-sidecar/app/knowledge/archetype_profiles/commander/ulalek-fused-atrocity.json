  "tells": [
    "Common mistakes include overcommitting to combat too early without securing the spell engine, or failing to use Golem tokens for mana acceleration.",
    "Remember that Ulalek's upkeep trigger creates tokens for the entire turn, so casting spells in response to upkeep can double-dip.",
    "Protect your signets and mana rocks, as they are critical for five-color consistency.",
    "Avoid casting your most valuable noncreature spells when opponents have visible sweepers unless you have a guaranteed answer."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast Sol Ring/Arcane Signet if possible, or cast a cheap cantrip/ramp spell."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Develop your mana base, cast another noncreature spell to trigger Ulalek if it's on board, or play a cheap creature/spellslinger."
    },
    {
      "trigger": "early game",
      "line": "Land sequencing: Prioritize fetches/shocks to find basics for signets, then duals for five-color fixing."
    }
  ],
