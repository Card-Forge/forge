    {
      "trigger": "early game",
      "line": "Turn 1: Play a land, cast Sol Ring/Arcane Signet, or cast a cheap ramp spell."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Cast a 2-3 mana Dragon or another ramp piece."
    },
    {
      "trigger": "early game",
