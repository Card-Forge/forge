  "tells": [
    "Consult the Star Charts is powerful but can backfire if you discard your own Kaheera or key answers",
    "use it when you have a full hand or can mitigate the discard.",
    "Kaheera's lifelink and vigilance make it excellent for trading life, but be wary of board wipes and targeted removal.",
    "Thoughtseize is your best early-game tool",
    "do not be afraid to use it on lands if the opponent is mana-screwed, but prioritize non-lands."
  ],
  "predicted_lines": [
    {
      "trigger": "early game",
      "line": "Turn 1: Cast Thoughtseize on a key non-land card (discard a threat, ramp piece, or combo piece)."
    },
    {
      "trigger": "early game",
      "line": "Turn 2: Play a land, then cast a counterspell, removal, or another Thoughtseize/Consult if possible."
